# macOS
.DS_Store

# build artifacts
/build/
a.out
*.o

# emulator core: large prebuilt binary + zipped copy (fetch separately);
# retroshot is built from tools/emu/harness.c
tools/emu/*.dylib
tools/emu/*.zip
tools/emu/retroshot
tools/__pycache__/

# test saves + scratch (user data, not source)
*.SRM
*.srm
*.sav
*.xlsx
current goal.txt

# browser-tool custom bakes (generated; makefont.py/makewaves.py pick them up if present)
tools/*_custom.bin

# local-only docs (kept on disk, not in the public repo; re-add later with `git add -f`)
#   TESTING.md     — internal QA checklist (references private dev ROMs)
#   CLAUDE.md      — AI-assistant project context
#   COMMANDS.md    — internal command-set reconciliation / decision log (stale; not a user reference)
#   MIDI.md        — MIDI-input design/build notes (parked; console side built, S3 wire pending)
#   HWTEST.md      — internal hardware test checklist (references dev ROMs; open-bug TODOs)
#   M1.md          — M1 boot milestone dev note
#   PURGE.md       — purge-logic spec / note-to-self for the SMSGGDJ port
#   MEGADRIVE.md   — early forward-notes, superseded by DESIGN.md
#   PLAN.md        — vision / milestone roadmap / risks
#   DESIGN.md      — design contract + decision log
#   COMPRESSION.md — RLE codec internals
#   SAVEFORMAT.md  — SRAM/.gmdj save-format internals
# (public docs kept tracked: MANUAL.md, CONTROLS.md, PALETTE.md, PRESETS.md)
TESTING.md
CLAUDE.md
COMMANDS.md
MIDI.md
HWTEST.md
M1.md
